{
  "name": "mototrack-track-agent",
  "main": "src/index.js",
  "compatibility_date": "2026-04-01",
  "routes": [
    {
      "pattern": "agent.mototrack.app",
      "custom_domain": true
    }
  ],
  "ai": {
    "binding": "AI"
  },
  "vars": {
    "TRACK_AGENT_AI_MODEL": "@cf/meta/llama-3.1-8b-instruct-fast",
    "TRACK_AGENT_AI_TIMEOUT_MS": "8000",
    "TRACK_AGENT_AI_MAX_INPUT_CHARS": "4000",
    "TRACK_AGENT_AI_MAX_OUTPUT_TOKENS": "1200"
  },
  "d1_databases": [
    {
      "binding": "TRACK_AGENT_DB",
      "database_name": "mototrack_track_agent",
      "database_id": "TODO_CREATE_D1_DATABASE_AND_FILL_ID"
    }
  ]
}
